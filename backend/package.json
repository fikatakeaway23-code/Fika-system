{
  "name": "fika-backend",
  "version": "1.0.0",
  "description": "Fika Takeaway backend API — Node.js + Express + PostgreSQL + Prisma",
  "main": "src/app.js",
  "scripts": {
    "dev": "tsx watch src/app.js",
    "start": "tsx src/app.js",
    "build": "tsc",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "test:smoke": "node --test tests/smoke.test.js"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "streamifier": "^0.1.1",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/streamifier": "^0.1.2",
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
